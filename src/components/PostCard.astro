---
import TopicPill from "./TopicPill.astro";

interface Props {
  slug: string;
  title: string;
  description: string;
  date: string;
  tags: string[];
}

const { slug, title, description, date, tags } = Astro.props;

const dateDisplay = new Date(date + "T00:00:00").toLocaleDateString("en-US", {
  year: "numeric",
  month: "short",
  day: "numeric",
});
---

<article class="bg-white dark:bg-surface-card-dark border border-gray-200 dark:border-gray-700 rounded-lg p-5 hover:shadow-md transition-shadow">
  <a href={`/blog/${slug}`} class="block group">
    <div class="flex items-baseline justify-between gap-4 mb-2">
      <h3 class="text-sm font-semibold text-primary dark:text-gray-100 group-hover:text-accent dark:group-hover:text-accent transition-colors">
        {title}
      </h3>
      <time class="text-xs text-gray-400 dark:text-gray-500 shrink-0">{dateDisplay}</time>
    </div>
    <p class="text-xs text-gray-500 dark:text-gray-400 leading-relaxed">{description}</p>
  </a>
  {tags.length > 0 && (
    <div class="flex flex-wrap gap-1.5 mt-4">
      {tags.map((tag: string) => (
        <TopicPill tag={tag} size="sm" />
      ))}
    </div>
  )}
</article>
