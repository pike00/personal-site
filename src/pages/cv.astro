---
export const prerender = true;
import PageLayout from "../layouts/PageLayout.astro";

const levelLabel = (level: number) =>
  ["", "Beginner", "Intermediate", "Proficient", "Advanced", "Expert"][level] ?? "";

const languages = [
  { name: "Python", level: 5 },
  { name: "R", level: 5 },
  { name: "TypeScript / JavaScript", level: 3 },
  { name: "SQL", level: 3 },
  { name: "Bash / Shell", level: 3 },
];

const llmPlatforms = [
  { name: "Claude", level: 5 },
  { name: "Claude Code", level: 5 },
  { name: "Gemini", level: 5 },
  { name: "OpenAI", level: 4 },
];
---

<PageLayout
  title="CV"
  description="Curriculum vitae for Will Pike, MD -- physician-clinical informatician specializing in real-world evidence."
>
  <!-- Header -->
  <section class="bg-gradient-to-br from-primary to-primary-light text-white relative overflow-hidden">
    <div class="absolute top-[-60px] right-[-40px] w-80 h-80 rounded-full bg-accent/10 blur-3xl"></div>
    <div class="max-w-4xl mx-auto px-6 py-16 md:py-20 relative z-10">
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6">
        <div>
          <p class="text-xs uppercase tracking-[3px] text-accent font-semibold mb-3">
            Curriculum Vitae
          </p>
          <h1 class="text-3xl md:text-4xl font-extrabold tracking-tight mb-2">
            Will Pike, MD
          </h1>
          <p class="text-gray-300 text-lg">
            Physician-Clinical Informatician
          </p>
          <div class="flex flex-wrap gap-x-5 gap-y-2 mt-4 text-sm text-gray-300">
            <a href="https://linkedin.com/in/pike00" class="flex items-center gap-1.5 hover:text-white transition-colors">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
              LinkedIn
            </a>
            <a href="https://github.com/pike00" class="flex items-center gap-1.5 hover:text-white transition-colors">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
              </svg>
              GitHub
            </a>
            <span class="flex items-center gap-1.5">
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
                <path d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
              </svg>
              Remote / Chicago, IL
            </span>
          </div>
        </div>

      </div>
    </div>
  </section>

  <div class="max-w-4xl mx-auto px-6 py-12 space-y-14">
    <!-- Summary -->
    <section>
      <p class="text-lg text-gray-600 dark:text-gray-300 leading-relaxed border-l-4 border-accent pl-5">
        Physician-Clinical Informatician specializing in real-world evidence. Builds scalable tools
        and processes that transform clinical data into research-grade evidence.
      </p>
    </section>

    <!-- Experience -->
    <section>
      <h2 class="text-xs uppercase tracking-[3px] text-accent font-semibold mb-6">Experience</h2>
      <div class="space-y-6">
        <!-- Atropos Health -->
        <div class="bg-white dark:bg-surface-card-dark rounded-xl border border-gray-200 dark:border-gray-700 p-6 hover:shadow-md transition-shadow">
          <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-1 mb-3">
            <div>
              <h3 class="text-lg font-bold text-primary dark:text-white">Director of Medical Informatics and Innovation</h3>
              <p class="text-accent font-semibold text-sm">Atropos Health</p>
            </div>
            <div class="text-sm text-gray-500 dark:text-gray-400 sm:text-right shrink-0">
              <p>July 2023 - present</p>
              <p>Remote</p>
            </div>
          </div>
          <ul class="space-y-2 text-sm text-gray-600 dark:text-gray-300 leading-relaxed">
            <li class="flex gap-2">
              <span class="text-accent mt-1 shrink-0">&#8226;</span>
              Lead clinical informatics strategy for an RWE company, designing scalable workflows for data transformation and semantic normalization across EHR, claims, and structured/unstructured clinical data sources
            </li>
            <li class="flex gap-2">
              <span class="text-accent mt-1 shrink-0">&#8226;</span>
              Build automated tools (Python, SQL) for data quality checks, concept identification, cohort definition, and clinical vocabulary mapping to improve research delivery
            </li>
            <li class="flex gap-2">
              <span class="text-accent mt-1 shrink-0">&#8226;</span>
              Serve as clinical SME translating complex medical concepts into computable phenotypes and standardized data representations for cross-functional engineering and data science teams
            </li>
            <li class="flex gap-2">
              <span class="text-accent mt-1 shrink-0">&#8226;</span>
              Drive knowledge management, process automation, and documentation across clinical evidence pipelines
            </li>
          </ul>
        </div>

        <!-- Johns Hopkins -->
        <div class="bg-white dark:bg-surface-card-dark rounded-xl border border-gray-200 dark:border-gray-700 p-6 hover:shadow-md transition-shadow">
          <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-1 mb-3">
            <div>
              <h3 class="text-lg font-bold text-primary dark:text-white">Emergency Medicine Resident</h3>
              <p class="text-accent font-semibold text-sm">Johns Hopkins University</p>
            </div>
            <div class="text-sm text-gray-500 dark:text-gray-400 sm:text-right shrink-0">
              <p>2022 - 2023</p>
              <p>Baltimore, MD</p>
            </div>
          </div>
          <ul class="space-y-2 text-sm text-gray-600 dark:text-gray-300 leading-relaxed">
            <li class="flex gap-2">
              <span class="text-accent mt-1 shrink-0">&#8226;</span>
              Completed intern year across Emergency Medicine, Anesthesiology, Critical Care, and Radiology
            </li>
            <li class="flex gap-2">
              <span class="text-accent mt-1 shrink-0">&#8226;</span>
              Vice-Chairman, Informatics Committee -- led EMR optimization, clinical documentation tooling, and technology resources for the department
            </li>
          </ul>
        </div>
      </div>
    </section>

    <!-- Education -->
    <section>
      <h2 class="text-xs uppercase tracking-[3px] text-accent font-semibold mb-6">Education</h2>
      <div class="space-y-4">
        <!-- Georgia Tech -->
        <div class="bg-white dark:bg-surface-card-dark rounded-xl border border-gray-200 dark:border-gray-700 p-5 hover:shadow-md transition-shadow">
          <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-1">
            <div>
              <h3 class="font-bold text-primary dark:text-white">Georgia Institute of Technology</h3>
              <p class="text-sm text-gray-600 dark:text-gray-300">MS in Analytics</p>
            </div>
            <div class="text-sm text-gray-500 dark:text-gray-400 sm:text-right shrink-0">
              <p>2024 - present</p>
              <p>Remote</p>
            </div>
          </div>
        </div>

        <!-- Georgetown -->
        <div class="bg-white dark:bg-surface-card-dark rounded-xl border border-gray-200 dark:border-gray-700 p-5 hover:shadow-md transition-shadow">
          <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-1">
            <div>
              <h3 class="font-bold text-primary dark:text-white">Georgetown University School of Medicine</h3>
              <p class="text-sm text-gray-600 dark:text-gray-300">MD in Medicine</p>
              <p class="text-sm text-accent font-medium mt-1">Magna Cum Laude</p>
            </div>
            <div class="text-sm text-gray-500 dark:text-gray-400 sm:text-right shrink-0">
              <p>2018 - 2022</p>
              <p>Washington, DC</p>
            </div>
          </div>
        </div>

        <!-- UVA -->
        <div class="bg-white dark:bg-surface-card-dark rounded-xl border border-gray-200 dark:border-gray-700 p-5 hover:shadow-md transition-shadow">
          <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-1">
            <div>
              <h3 class="font-bold text-primary dark:text-white">University of Virginia</h3>
              <p class="text-sm text-gray-600 dark:text-gray-300">BA with Distinction in Biology</p>
              <p class="text-sm text-accent font-medium mt-1">GPA: 4.0/4.0 -- graduated in 3 years</p>
            </div>
            <div class="text-sm text-gray-500 dark:text-gray-400 sm:text-right shrink-0">
              <p>2014 - 2017</p>
              <p>Charlottesville, VA</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Publications -->
    <section>
      <h2 class="text-xs uppercase tracking-[3px] text-accent font-semibold mb-6">Publications</h2>
      <a
        href="/publications"
        class="block bg-white dark:bg-surface-card-dark rounded-xl border border-gray-200 dark:border-gray-700 p-6 hover:shadow-md hover:border-accent/50 transition-all group"
      >
        <div class="flex items-center justify-between">
          <div>
            <p class="text-sm text-gray-600 dark:text-gray-300 leading-relaxed">
              Peer-reviewed publications spanning RWE, clinical outcomes, and health informatics
            </p>
            <p class="text-sm text-accent font-medium mt-2">
              View full publication list &rarr;
            </p>
          </div>
          <svg class="w-5 h-5 text-gray-400 group-hover:text-accent transition-colors shrink-0 ml-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
          </svg>
        </div>
      </a>
    </section>

    <!-- Skills -->
    <section>
      <h2 class="text-xs uppercase tracking-[3px] text-accent font-semibold mb-6">Skills</h2>
      <div class="grid md:grid-cols-2 gap-6">
        <div class="bg-white dark:bg-surface-card-dark rounded-xl border border-gray-200 dark:border-gray-700 p-5">
          <h3 class="text-sm font-bold text-primary dark:text-white mb-4">Languages</h3>
          <div class="space-y-3">
            {languages.map(({ name, level }) => (
              <div>
                <div class="flex items-center justify-between mb-1">
                  <span class="text-sm font-semibold text-primary dark:text-white">{name}</span>
                  <span class="text-xs text-gray-500 dark:text-gray-400">{levelLabel(level)}</span>
                </div>
                <div class="h-1.5 rounded-full bg-gray-200 dark:bg-gray-700 overflow-hidden">
                  <div class="h-full rounded-full bg-accent" style={`width: ${level * 20}%`} />
                </div>
              </div>
            ))}
          </div>
        </div>
        <div class="bg-white dark:bg-surface-card-dark rounded-xl border border-gray-200 dark:border-gray-700 p-5">
          <h3 class="text-sm font-bold text-primary dark:text-white mb-4">LLM Experience</h3>
          <div class="space-y-3">
            {llmPlatforms.map(({ name, level }) => (
              <div>
                <div class="flex items-center justify-between mb-1">
                  <span class="text-sm font-semibold text-primary dark:text-white">{name}</span>
                  <span class="text-xs text-gray-500 dark:text-gray-400">{levelLabel(level)}</span>
                </div>
                <div class="h-1.5 rounded-full bg-gray-200 dark:bg-gray-700 overflow-hidden">
                  <div class="h-full rounded-full bg-accent" style={`width: ${level * 20}%`} />
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>
  </div>
</PageLayout>
