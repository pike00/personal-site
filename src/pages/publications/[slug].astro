---
import PageLayout from "../../layouts/PageLayout.astro";
import TopicPill from "../../components/TopicPill.astro";
import { getPublications } from "../../lib/publications";
import type { Publication } from "../../lib/types";

export function getStaticPaths() {
  const publications = getPublications();
  return publications.map((pub) => ({
    params: { slug: pub.slug },
    props: { publication: pub },
  }));
}

interface Props {
  publication: Publication;
}

const { publication: pub } = Astro.props;

const authorDisplay = pub.authors
  .map((a) => (/\bPike\b/.test(a) ? `<strong>${a}</strong>` : a))
  .join(", ");

const year = pub.pubDate ? pub.pubDate.split("-")[0] : "";
const dateDisplay = pub.pubDate
  ? new Date(pub.pubDate + "T00:00:00").toLocaleDateString("en-US", {
      year: "numeric",
      month: "long",
      day: "numeric",
    })
  : "";
---

<PageLayout
  title={pub.title}
  description={`${pub.title}. ${pub.journal}${year ? `, ${year}` : ""}`}
>
  <div class="max-w-3xl mx-auto px-6 py-12">
    <nav class="text-sm text-gray-400 dark:text-gray-500 mb-8">
      <a href="/publications" class="hover:text-accent transition-colors">Publications</a>
      <span class="mx-2">/</span>
      <span class="text-gray-600 dark:text-gray-300 max-sm:truncate max-sm:inline-block max-sm:max-w-[250px] align-bottom">{pub.title}</span>
    </nav>

    <h1 class="text-2xl font-bold text-primary dark:text-white leading-snug mb-4">
      {pub.title}
    </h1>

    {pub.authors.length > 0 && (
      <p class="text-sm text-gray-600 dark:text-gray-300 mb-2" set:html={authorDisplay} />
    )}

    {pub.journal && (
      <p class="text-sm text-gray-500 dark:text-gray-400 mb-6">
        <span class="italic">{pub.journal}</span>
        {pub.volume && `, ${pub.volume}`}
        {pub.issue && `(${pub.issue})`}
        {pub.pages && `: ${pub.pages}`}
        {year && ` (${year})`}
      </p>
    )}

    {pub.researchArea.length > 0 && (
      <div class="flex flex-wrap gap-2 mb-8">
        {pub.researchArea.map((tag) => (
          <TopicPill tag={tag} href={`/publications?tag=${encodeURIComponent(tag)}`} size="sm" />
        ))}
      </div>
    )}

    {pub.pdfPath && (
      <div class="mb-8">
        <a
          href={`/${pub.pdfPath}`}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-4 py-2 bg-accent hover:bg-accent-dark text-white rounded-lg text-sm font-medium transition-colors"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          View PDF
          <svg class="w-3 h-3 opacity-60" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>
      </div>
    )}

    <div class="border-t border-gray-200 dark:border-gray-700 pt-6">
      <h2 class="text-sm font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-4">Details</h2>
      <dl class="grid grid-cols-[auto_1fr] gap-x-6 gap-y-3 text-sm">
        {pub.pubType && (
          <>
            <dt class="text-gray-500 dark:text-gray-400">Publication Type</dt>
            <dd class="text-primary dark:text-gray-200">{pub.pubType}</dd>
          </>
        )}
        {pub.journal && (
          <>
            <dt class="text-gray-500 dark:text-gray-400">Journal</dt>
            <dd class="text-primary dark:text-gray-200">{pub.journal}</dd>
          </>
        )}
        {pub.pubDate && (
          <>
            <dt class="text-gray-500 dark:text-gray-400">Date Published</dt>
            <dd class="text-primary dark:text-gray-200">{dateDisplay}</dd>
          </>
        )}
        {pub.volume && (
          <>
            <dt class="text-gray-500 dark:text-gray-400">Volume</dt>
            <dd class="text-primary dark:text-gray-200">{pub.volume}</dd>
          </>
        )}
        {pub.issue && (
          <>
            <dt class="text-gray-500 dark:text-gray-400">Issue</dt>
            <dd class="text-primary dark:text-gray-200">{pub.issue}</dd>
          </>
        )}
        {pub.pages && (
          <>
            <dt class="text-gray-500 dark:text-gray-400">Pages</dt>
            <dd class="text-primary dark:text-gray-200">{pub.pages}</dd>
          </>
        )}
        {pub.doi && (
          <>
            <dt class="text-gray-500 dark:text-gray-400">Digital Object Identifier</dt>
            <dd class="text-primary dark:text-gray-200">
              <a
                href={`https://doi.org/${pub.doi}`}
                target="_blank"
                rel="noopener noreferrer"
                class="text-accent hover:underline inline-flex items-center gap-1"
              >
                {pub.doi}
                <svg class="w-3 h-3 opacity-60" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </a>
            </dd>
          </>
        )}
        {pub.id && (
          <>
            <dt class="text-gray-500 dark:text-gray-400">PubMed Identifier</dt>
            <dd class="text-primary dark:text-gray-200">
              <a
                href={`https://pubmed.ncbi.nlm.nih.gov/${pub.id}/`}
                target="_blank"
                rel="noopener noreferrer"
                class="text-accent hover:underline inline-flex items-center gap-1"
              >
                {pub.id}
                <svg class="w-3 h-3 opacity-60" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </a>
            </dd>
          </>
        )}
        {pub.pmcId && (
          <>
            <dt class="text-gray-500 dark:text-gray-400">PubMed Central Identifier</dt>
            <dd class="text-primary dark:text-gray-200">
              <a
                href={`https://www.ncbi.nlm.nih.gov/pmc/articles/${pub.pmcId}/`}
                target="_blank"
                rel="noopener noreferrer"
                class="text-accent hover:underline inline-flex items-center gap-1"
              >
                {pub.pmcId}
                <svg class="w-3 h-3 opacity-60" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                </svg>
              </a>
            </dd>
          </>
        )}
      </dl>
    </div>

    {pub.pdfPath && (
      <div class="border-t border-gray-200 dark:border-gray-700 pt-6 mt-8">
        <h2 class="text-sm font-semibold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-4">Document Preview</h2>
        <div class="hidden md:block rounded-xl border border-gray-200 dark:border-gray-700 overflow-hidden bg-gray-100 dark:bg-gray-800">
          <iframe
            src={`/${pub.pdfPath}`}
            class="w-full"
            style="height: 80vh; min-height: 600px;"
            title={`PDF preview of ${pub.title}`}
          >
            <p class="p-6 text-sm text-gray-500">
              Your browser does not support embedded PDFs.
              <a href={`/${pub.pdfPath}`} target="_blank" rel="noopener noreferrer" class="text-accent hover:underline">
                Open the PDF directly.
              </a>
            </p>
          </iframe>
        </div>
        <a
          href={`/${pub.pdfPath}`}
          target="_blank"
          rel="noopener noreferrer"
          class="md:hidden inline-flex items-center gap-2 text-accent hover:underline text-sm"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          Open PDF
          <svg class="w-3 h-3 opacity-60" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>
      </div>
    )}
  </div>
</PageLayout>
